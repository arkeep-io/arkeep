# deploy/docker/.env.example — Copy to .env and fill in the values.
#
# NEVER commit .env to version control — it contains secrets.

# ── Required (server) ─────────────────────────────────────────────────────────

# Secret key used to sign JWT access tokens. Must be at least 32 characters.
# Generate with: openssl rand -hex 32
ARKEEP_SECRET_KEY=

# Shared secret between server and all agents. Must match on both sides.
# Generate with: openssl rand -hex 24
ARKEEP_AGENT_SECRET=

# ── Required (agent only — docker-compose.agent.yml) ─────────────────────────

# gRPC address of the Arkeep server. Must be reachable from this machine.
# Example: ARKEEP_SERVER_ADDR=arkeep.example.com:9090
ARKEEP_SERVER_ADDR=

# ── Optional ──────────────────────────────────────────────────────────────────

# Host ports exposed by the server (defaults shown).
ARKEEP_HTTP_PORT=8080
ARKEEP_GRPC_PORT=9090

# Log verbosity: debug | info | warn | error
ARKEEP_LOG_LEVEL=info

# Timezone for log timestamps.
TZ=UTC

# Database driver: sqlite (default) or postgres
ARKEEP_DB_DRIVER=sqlite

# SQLite: path inside the container (backed by a named volume).
# PostgreSQL: full DSN — uncomment and edit when using the postgres service.
ARKEEP_DB_DSN=/var/lib/arkeep/arkeep.db
# ARKEEP_DB_DSN=postgres://arkeep:${POSTGRES_PASSWORD}@postgres:5432/arkeep?sslmode=disable

# PostgreSQL password — only needed if you uncomment the postgres service.
# POSTGRES_PASSWORD=
