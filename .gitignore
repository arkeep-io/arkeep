# ─── Go ───────────────────────────────────────────────────────────────────────
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
go.work.sum
/bin/

# ─── Vue ──────────────────────────────────────────────────────────────────────
node_modules/
gui/dist/
gui/.env.local
gui/.env.*.local
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Development data ─────────────────────────────────────────────────────────
*.db
*.db-shm
*.db-wal
data/

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── IDE ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─── Environment / secrets ────────────────────────────────────────────────────
.env
.env.local
*.env

# ─── Helm ─────────────────────────────────────────────────────────────────────
# Subchart tarballs are regenerated with `helm dependency update`; only Chart.lock is committed.
deploy/helm/**/charts/*.tgz

# ─── Embedded binaries (populated by task deps:download, not committed) ───────
# Ignore all binaries in the bin/ directory except .gitkeep.
# Binaries are named with platform suffixes (e.g. restic_linux_amd64) so
# we ignore by pattern rather than explicit names.
agent/internal/restic/bin/*
!agent/internal/restic/bin/.gitkeep

# ─── Embedded GUI (populated by pnpm build + cp, not committed) ──────────────
# The dist/ directory is copied into the go:embed path by GoReleaser/Docker.
# Only .gitkeep is tracked so the empty directory compiles locally.
server/cmd/server/dist/*
!server/cmd/server/dist/.gitkeep